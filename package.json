{
  "name": "@notemine/wrapper",
  "version": "0.0.4",
  "author": "bread@sandwich.farm",
  "description": "Nostr note miner wrapper for notemine WASM",
  "repository": "https://github.com/sandwichfarm/notemine-js",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.js",
  "next": "./dist/index.esm.js",
  "browser": "./dist/index.amd.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "types": "tsc --emitDeclarationOnly",
    "ts": "tsc",
    "rollup": "rollup --config",
    "build": "yarn clean && yarn build:types && node build.js",
    "build:types": "tsc --emitDeclarationOnly",
    "dev": "node build.js",
    "clean": "rimraf dist",
    "start": "webpack --mode development",
    "test": "vitest"
  },
  "keywords": [
    "nostr",
    "wasm",
    "miner",
    "typescript",
    "rxjs"
  ],
  "dependencies": {
    "@aidenlx/esbuild-plugin-inline-worker": "1.0.1",
    "nostr-tools": "2.7.2",
    "notemine": "0.3.2",
    "rxjs": "7.8.1",
    "web-worker": "1.3.0"
  },
  "peerDependencies": {
    "nostr-tools": "^2.7.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@jgoz/esbuild-plugin-livereload": "2.1.1",
    "@rollup/plugin-commonjs": "28.0.0",
    "@rollup/plugin-node-resolve": "15.3.0",
    "@rollup/plugin-replace": "6.0.1",
    "@rollup/plugin-wasm": "6.2.2",
    "@surma/rollup-plugin-off-main-thread": "2.2.3",
    "@types/node": "22.5.5",
    "@types/webpack-env": "1.18.5",
    "@vitest/web-worker": "2.1.1",
    "css-loader": "^6.7.3",
    "esbuild": "0.24.0",
    "esbuild-plugin-clean": "1.0.1",
    "esbuild-plugin-inline-worker": "0.1.1",
    "esbuild-plugin-polyfill-node": "0.3.0",
    "esbuild-plugin-tsc": "0.4.0",
    "get-port": "7.1.0",
    "happy-dom": "15.7.4",
    "html-webpack-plugin": "^5.5.0",
    "mini-css-extract-plugin": "^2.7.5",
    "rimraf": "6.0.1",
    "rollup": "4.22.4",
    "rollup-plugin-copy": "3.5.0",
    "rollup-plugin-livereload": "2.0.5",
    "rollup-plugin-terser": "7.0.2",
    "rollup-plugin-typescript2": "0.36.0",
    "rollup-plugin-web-worker-loader": "1.6.1",
    "svelte": "4.2.19",
    "svelte-loader": "^3.2.0",
    "ts-loader": "9.5.1",
    "typescript": "5.6.2",
    "vitest": "2.1.1",
    "webpack": "5.94.0",
    "webpack-cli": "5.1.4",
    "webpack-dev-server": "5.1.0",
    "worker-loader": "3.0.8"
  }
}
